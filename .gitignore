# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Mac / OS
.DS_Store
**/.DS_Store

# Build artifacts
build/

# Data / outputs — regenerierbar (python -m src.merge, plot_alignment.py …)
data/processed/
data/raw/
# Why: die Joblibs sind zu groß (MB) und regenerierbar, daher models/-Inhalte
# ignored. hmm_live.json ist dagegen ein winziges, deploybares Live-Artefakt
# (2x2-Matrix + Prior), das die Inferenz zur Laufzeit braucht -> per Negation
# mitversioniert. models/* (statt models/) lässt das Re-Include zu — ein
# komplett ausgeschlossenes Verzeichnis kann git nicht re-includen.
models/*
!models/hmm_live.json
results/plots/*.png
results/plots/*.jpg
results/metrics/*.csv

# Misc
.env

# Stray pen logs (manual pen_logger.py runs without --session)
pen_log_*.csv

# Stray markdown reports written outside reports/
data/session_*_report*.md
data/raw/**/session_*_report*.md

# Local model progression timeline (working doc, not for the repo)
reports/model_progression.md

# Server logs
logs/


# Visual Companion brainstorming session artefacts
.superpowers/
docs/superpowers/

# Study Mode markers (regenerated per-session by the server)
data/raw/markers/

# Session index — owned by the running server, derivable from data/raw/.
# Previously tracked, which led to git operations overwriting working-tree
# rows (e.g. uncommitted session_stop appends getting wiped on a checkout).
data/sessions.csv

# Focus-Tracker live-inference log — append-only at 1 Hz while server runs,
# grows ~3 MB/day. Local artefact, not part of the repo.
data/inference_log.csv

# Local pipeline overview — personal cheat sheet, not part of repo docs.
ML_PIPELINE_OVERVIEW.md

# Internal idea backlog — brainstorming, not part of repo docs.
projektideen.md

# Forecast / Lernkurven-Prognose — Research-Tooling + Artefakte,
# nicht Teil der operativen Pipeline.
forecast/

# Xcode per-user IDE state (window layout, cursor positions, breakpoints).
# Regenerates on every open and creates noisy diffs.
**/xcuserdata/
*.xcuserstate

# Pasted macOS screenshots (verification artifacts, not repo docs).
Bildschirmfoto*.png
Screenshot*.png
